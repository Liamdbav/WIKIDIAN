{
  "manifest_version": 3,
  "name": "Wikidian",
  "version": "0.1.0",
  "description": "Capture Wikipedia articles and save them as Markdown notes in Obsidian via Local REST API.",

  "permissions": ["storage", "activeTab", "tabs", "scripting"],

  "host_permissions": [
    "*://*.wikipedia.org/*",
    "http://127.0.0.1:27123/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.wikipedia.org/wiki/*"],
      "js": ["lib/turndown.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Wikidian"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
